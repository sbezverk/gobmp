{
  "schema_version": 1,
  "name": "vpnv4-announce",
  "description": "Inject a VPNv4 announcement with label and route target.",
  "tags": ["vpnv4", "l3vpn", "mpls-label", "announce", "manual-inject"],
  "inject": {
    "path": "/v1/routes",
    "body": {
      "address_family": "vpnv4",
      "action": "announce",
      "source": "manual-fixture",
      "collector": "validator-v2",
      "sequence_id": "vpnv4-announce-001",
      "nlri": {
        "labels": [
          { "value": 1000, "exp": 0, "is_bos": true }
        ],
        "rd": "50123:100",
        "prefix": "10.255.100.0/24"
      },
      "next_hops": ["10.2.1.5"],
      "as_path_segments": [
        { "type": "as_sequence", "asns": [64512, 64513] }
      ],
      "origin": "igp",
      "extended_communities": [
        { "type": "route_target", "format": "two_octet_as", "asn": 50123, "local": 100 }
      ]
    }
  },
  "observe": {
    "source": "kafka",
    "topic": "gobmp.parsed.l3vpn_v4",
    "timeout": "120",
    "match": {
      "action": "add",
      "vpn_rd": "50123:100",
      "prefix": "10.255.100.0",
      "prefix_len": 24
    }
  },
  "expect": {
    "equals": {
      "action": "add",
      "vpn_rd": "50123:100",
      "prefix": "10.255.100.0",
      "prefix_len": 24,
      "is_ipv4": true,
      "nexthop": "10.2.1.5"
    },
    "contains": {
      "labels": [1000],
      "base_attrs": {
        "origin": "igp",
        "as_path": [50123, 64512, 64513]
      }
    },
    "present": ["timestamp", "peer_ip", "router_hash", "base_attrs"],
    "absent": ["error"]
  },
  "cleanup": {
    "path": "/v1/routes",
    "body": {
      "address_family": "vpnv4",
      "action": "withdraw",
      "nlri": {
        "labels": [
          { "value": 1000, "exp": 0, "is_bos": true }
        ],
        "rd": "50123:100",
        "prefix": "10.255.100.0/24"
      }
    }
  }
}
