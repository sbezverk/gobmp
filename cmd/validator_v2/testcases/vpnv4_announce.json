{
  "schema_version": 1,
  "name": "vpnv4-announce",
  "description": "Inject a VPNv4 announcement with label and route target.",
  "tags": ["vpnv4", "l3vpn", "mpls-label", "announce", "manual-inject"],
  "inject": {
    "path": "/v1/routes",
    "body": {
      "address_family": "vpnv4",
      "action": "announce",
      "source": "manual-fixture",
      "collector": "validator-v2",
      "sequence_id": "vpnv4-announce-001",
      "nlri": {
        "labels": [
          { "value": 1000, "exp": 0, "is_bos": true }
        ],
        "rd": "50123:100",
        "prefix": "10.255.100.0/24"
      },
      "next_hops": ["10.2.1.5"],
      "as_path_segments": [
        { "type": "as_sequence", "asns": [64512, 64513] }
      ],
      "origin": "igp",
      "med": 500,
      "communities": ["64512:500"],
      "large_communities": [
        { "global_admin": 64512, "local_data_1": 50, "local_data_2": 500 }
      ],
      "extended_communities": [
        { "type": "route_target", "format": "two_octet_as", "asn": 50123, "local": 100 }
      ]
    }
  },
  "observe": {
    "source": "kafka",
    "topic": "gobmp.parsed.l3vpn_v4",
    "timeout": "120",
    "match": {
      "action": "add",
      "vpn_rd": "50123:100",
      "prefix": "10.255.100.0",
      "prefix_len": 24
    }
  },
  "expect": {
    "equals": {
      "action": "add",
      "router_ip": "10.2.1.3",
      "peer_ip": "10.2.1.5",
      "peer_type": 0,
      "peer_asn": 50123,
      "vpn_rd": "50123:100",
      "vpn_rd_type": 0,
      "prefix": "10.255.100.0",
      "prefix_len": 24,
      "is_ipv4": true,
      "origin_as": 64513,
      "nexthop": "10.2.1.5",
      "is_nexthop_ipv4": true,
      "labels": [1000],
      "is_adj_rib_in_post_policy": false,
      "is_adj_rib_out_post_policy": false,
      "is_adj_rib_out": false,
      "is_loc_rib": false,
      "is_loc_rib_filtered": false
    },
    "contains": {
      "labels": [1000],
      "base_attrs": {
        "origin": "igp",
        "as_path": [50123, 64512, 64513],
        "as_path_count": 3,
        "med": 500,
        "is_atomic_agg": false,
        "community_list": ["64512:500"],
        "large_community_list": ["64512:50:500"],
        "ext_community_list": ["rt=50123:100"]
      }
    },
    "present": ["timestamp", "router_hash", "peer_hash", "base_attrs", "base_attrs.base_attr_hash"],
    "absent": ["error", "is_eor"]
  },
  "cleanup": {
    "path": "/v1/routes",
    "body": {
      "address_family": "vpnv4",
      "action": "withdraw",
      "nlri": {
        "labels": [
          { "value": 1000, "exp": 0, "is_bos": true }
        ],
        "rd": "50123:100",
        "prefix": "10.255.100.0/24"
      }
    }
  }
}
