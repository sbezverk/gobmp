{
  "schema_version": 1,
  "name": "vpnv6-withdraw",
  "description": "Withdraw the VPNv6 route created by vpnv6-announce.",
  "tags": ["vpnv6", "l3vpn", "withdraw", "manual-inject", "requires-existing-route"],
  "inject": {
    "path": "/v1/routes",
    "body": {
      "address_family": "vpnv6",
      "action": "withdraw",
      "nlri": {
        "labels": [
          { "value": 1000, "exp": 0, "is_bos": true }
        ],
        "rd": "50123:200",
        "prefix": "2001:db8:5012:200::/64"
      }
    }
  },
  "observe": {
    "source": "kafka",
    "topic": "gobmp.parsed.l3vpn_v6",
    "timeout": "120",
    "match": {
      "action": "del",
      "vpn_rd": "50123:200",
      "prefix": "2001:db8:5012:200::",
      "prefix_len": 64
    }
  },
  "expect": {
    "equals": {
      "action": "del",
      "router_ip": "10.2.1.3",
      "peer_ip": "10.2.1.5",
      "peer_type": 0,
      "peer_asn": 50123,
      "vpn_rd": "50123:200",
      "vpn_rd_type": 0,
      "prefix": "2001:db8:5012:200::",
      "prefix_len": 64,
      "is_ipv4": false,
      "is_nexthop_ipv4": false,
      "labels": [1000],
      "is_adj_rib_in_post_policy": false,
      "is_adj_rib_out_post_policy": false,
      "is_adj_rib_out": false,
      "is_loc_rib": false,
      "is_loc_rib_filtered": false
    },
    "contains": {
      "labels": [1000],
      "base_attrs": {
        "is_atomic_agg": false
      }
    },
    "present": ["timestamp", "router_hash", "peer_hash", "base_attrs", "base_attrs.base_attr_hash"],
    "absent": ["error", "is_eor"]
  }
}
