{
  "schema_version": 1,
  "name": "vpnv6-withdraw",
  "description": "Withdraw the VPNv6 route created by vpnv6-announce.",
  "tags": ["vpnv6", "l3vpn", "withdraw", "manual-inject", "requires-existing-route"],
  "inject": {
    "path": "/v1/routes",
    "body": {
      "address_family": "vpnv6",
      "action": "withdraw",
      "nlri": {
        "labels": [
          { "value": 1000, "exp": 0, "is_bos": true }
        ],
        "rd": "50123:200",
        "prefix": "2001:db8:5012:200::/64"
      }
    }
  },
  "observe": {
    "source": "kafka",
    "topic": "gobmp.parsed.l3vpn_v6",
    "timeout": "120",
    "match": {
      "action": "del",
      "vpn_rd": "50123:200",
      "prefix": "2001:db8:5012:200::",
      "prefix_len": 64
    }
  },
  "expect": {
    "equals": {
      "action": "del",
      "vpn_rd": "50123:200",
      "prefix": "2001:db8:5012:200::",
      "prefix_len": 64,
      "is_ipv4": false
    },
    "contains": {
      "labels": [1000]
    },
    "present": ["timestamp", "peer_ip", "router_hash"],
    "absent": ["error"]
  }
}
