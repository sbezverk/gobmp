{
  "schema_version": 1,
  "name": "vpnv6-announce",
  "description": "Inject a VPNv6 announcement with label and route target.",
  "tags": ["vpnv6", "l3vpn", "mpls-label", "announce", "manual-inject"],
  "inject": {
    "path": "/v1/routes",
    "body": {
      "address_family": "vpnv6",
      "action": "announce",
      "source": "manual-fixture",
      "collector": "validator-v2",
      "sequence_id": "vpnv6-announce-001",
      "nlri": {
        "labels": [
          { "value": 1000, "exp": 0, "is_bos": true }
        ],
        "rd": "50123:200",
        "prefix": "2001:db8:5012:200::/64"
      },
      "next_hops": ["2001:db8:2:1::5"],
      "as_path_segments": [
        { "type": "as_sequence", "asns": [64512, 64513] }
      ],
      "origin": "igp",
      "extended_communities": [
        { "type": "route_target", "format": "two_octet_as", "asn": 50123, "local": 200 }
      ]
    }
  },
  "observe": {
    "source": "kafka",
    "topic": "gobmp.parsed.l3vpn_v6",
    "timeout": "120",
    "match": {
      "action": "add",
      "vpn_rd": "50123:200",
      "prefix": "2001:db8:5012:200::",
      "prefix_len": 64
    }
  },
  "expect": {
    "equals": {
      "action": "add",
      "vpn_rd": "50123:200",
      "prefix": "2001:db8:5012:200::",
      "prefix_len": 64,
      "is_ipv4": false,
      "nexthop": "2001:db8:2:1::5"
    },
    "contains": {
      "labels": [1000],
      "base_attrs": {
        "origin": "igp",
        "as_path": [50123, 64512, 64513]
      }
    },
    "present": ["timestamp", "peer_ip", "router_hash", "base_attrs"],
    "absent": ["error"]
  },
  "cleanup": {
    "path": "/v1/routes",
    "body": {
      "address_family": "vpnv6",
      "action": "withdraw",
      "nlri": {
        "labels": [
          { "value": 1000, "exp": 0, "is_bos": true }
        ],
        "rd": "50123:200",
        "prefix": "2001:db8:5012:200::/64"
      }
    }
  }
}
