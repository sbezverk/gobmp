{
  "schema_version": 1,
  "name": "vpnv4-withdraw",
  "description": "Withdraw the VPNv4 route created by vpnv4-announce.",
  "tags": ["vpnv4", "l3vpn", "withdraw", "manual-inject", "requires-existing-route"],
  "inject": {
    "path": "/v1/routes",
    "body": {
      "address_family": "vpnv4",
      "action": "withdraw",
      "nlri": {
        "labels": [
          { "value": 1000, "exp": 0, "is_bos": true }
        ],
        "rd": "50123:100",
        "prefix": "10.255.100.0/24"
      }
    }
  },
  "observe": {
    "source": "kafka",
    "topic": "gobmp.parsed.l3vpn_v4",
    "timeout": "120",
    "match": {
      "action": "del",
      "vpn_rd": "50123:100",
      "prefix": "10.255.100.0",
      "prefix_len": 24
    }
  },
  "expect": {
    "equals": {
      "action": "del",
      "vpn_rd": "50123:100",
      "prefix": "10.255.100.0",
      "prefix_len": 24,
      "is_ipv4": true
    },
    "contains": {
      "labels": [1000]
    },
    "present": ["timestamp", "peer_ip", "router_hash"],
    "absent": ["error"]
  }
}
