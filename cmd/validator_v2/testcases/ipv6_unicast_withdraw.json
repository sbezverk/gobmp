{
  "schema_version": 1,
  "name": "ipv6-unicast-withdraw",
  "description": "Withdraw the IPv6 unicast route created by ipv6-unicast-announce.",
  "tags": ["ipv6", "unicast", "withdraw", "manual-inject", "requires-existing-route"],
  "inject": {
    "path": "/v1/routes",
    "body": {
      "address_family": "ipv6/unicast",
      "action": "withdraw",
      "nlri": {
        "prefix": "2001:db8:100::/48"
      }
    }
  },
  "observe": {
    "source": "kafka",
    "topic": "gobmp.parsed.unicast_prefix_v6",
    "timeout": "120",
    "match": {
      "action": "del",
      "prefix": "2001:db8:100::",
      "prefix_len": 48
    }
  },
  "expect": {
    "equals": {
      "action": "del",
      "router_ip": "10.2.1.3",
      "peer_ip": "10.2.1.5",
      "peer_type": 0,
      "peer_asn": 50123,
      "prefix": "2001:db8:100::",
      "prefix_len": 48,
      "is_ipv4": false,
      "is_nexthop_ipv4": false,
      "is_adj_rib_in_post_policy": false,
      "is_adj_rib_out_post_policy": false,
      "is_adj_rib_out": false,
      "is_loc_rib": false,
      "is_loc_rib_filtered": false
    },
    "contains": {
      "base_attrs": {
        "is_atomic_agg": false
      }
    },
    "present": ["timestamp", "base_attrs"],
    "non_empty": ["hash", "router_hash", "peer_hash", "base_attrs.base_attr_hash"],
    "absent": ["error", "is_eor"]
  }
}
